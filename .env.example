COMPOSE_PROJECT_NAME=jobprocessor
DOCKER_INTERNAL_NETWORK_NAME=jobprocessor-internal
DOCKER_EDGE_NETWORK_NAME=jobprocessor-edge

FRONTEND_IMAGE=job-frontend:latest
API_IMAGE=job-api:latest
WORKER_IMAGE=job-worker:latest
REDIS_IMAGE=redis:7.4-alpine

FRONTEND_HOST_PORT=3000
FRONTEND_PORT=3000
FRONTEND_HOST=0.0.0.0
FRONTEND_API_URL=http://api:8000
FRONTEND_REQUEST_TIMEOUT_MS=5000

API_HOST_PORT=8000
API_PORT=8000

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

JOB_QUEUE_NAME=job
JOB_PROCESSING_DELAY_SECONDS=2
WORKER_HEARTBEAT_FILE=/tmp/worker-heartbeat

FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=256m
API_CPU_LIMIT=0.50
API_MEMORY_LIMIT=256m
WORKER_CPU_LIMIT=0.50
WORKER_MEMORY_LIMIT=256m
REDIS_CPU_LIMIT=0.25
REDIS_MEMORY_LIMIT=128m
